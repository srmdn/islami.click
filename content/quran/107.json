{
  "number": 107,
  "name": "Al-Ma'un",
  "arabic_name": "الماعون",
  "translation": "Barang yang Berguna",
  "revelation_type": "meccan",
  "ayah_count": 7,
  "ayahs": [
    {
      "number": 1,
      "arabic": "أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ",
      "translation": "Tahukah kamu (orang) yang mendustakan agama"
    },
    {
      "number": 2,
      "arabic": "فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ",
      "translation": "Maka itulah orang yang menghardik anak yatim"
    },
    {
      "number": 3,
      "arabic": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ",
      "translation": "dan tidak mengajak memberi makan orang miskin"
    },
    {
      "number": 4,
      "arabic": "فَوَيۡلٞ لِّلۡمُصَلِّينَ",
      "translation": "Maka celakalah orang yang salat"
    },
    {
      "number": 5,
      "arabic": "ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ",
      "translation": "(yaitu) orang-orang yang lalai terhadap salatnya"
    },
    {
      "number": 6,
      "arabic": "ٱلَّذِينَ هُمۡ يُرَآءُونَ",
      "translation": "yang berbuat riya"
    },
    {
      "number": 7,
      "arabic": "وَيَمۡنَعُونَ ٱلۡمَاعُونَ",
      "translation": "dan enggan (memberikan) bantuan"
    }
  ]
}