{
  "number": 114,
  "name": "An-Nas",
  "arabic_name": "الناس",
  "translation": "Umat Manusia",
  "revelation_type": "meccan",
  "ayah_count": 6,
  "ayahs": [
    {
      "number": 1,
      "arabic": "قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ",
      "translation": "Katakanlah, \"Aku berlindung kepada Tuhannya manusia"
    },
    {
      "number": 2,
      "arabic": "مَلِكِ ٱلنَّاسِ",
      "translation": "Raja manusia"
    },
    {
      "number": 3,
      "arabic": "إِلَٰهِ ٱلنَّاسِ",
      "translation": "sembahan manusia"
    },
    {
      "number": 4,
      "arabic": "مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ",
      "translation": "dari kejahatan (bisikan) setan yang bersembunyi"
    },
    {
      "number": 5,
      "arabic": "ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ",
      "translation": "yang membisikkan (kejahatan) ke dalam dada manusia"
    },
    {
      "number": 6,
      "arabic": "مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ",
      "translation": "dari (golongan) jin dan manusia"
    }
  ]
}